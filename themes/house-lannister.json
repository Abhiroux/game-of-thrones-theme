  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#F0E0C0" } },

    { "name": "Comments – Whisperer", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5A4825", "fontStyle": "italic" } },

    { "name": "Keywords – Lion's Roar Crimson", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#CC0000", "fontStyle": "bold" } },
    { "name": "Operators", "scope": ["keyword.operator"], "settings": { "foreground": "#D4A850" } },

    { "name": "Strings – Casterly Gold", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#FFD700" } },
    { "name": "String Escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#88BB00" } },
    { "name": "Template Expression", "scope": ["punctuation.definition.template-expression"], "settings": { "foreground": "#E6B800" } },

    { "name": "Numbers – Rich Amber", "scope": ["constant.numeric"], "settings": { "foreground": "#E6B800" } },
    { "name": "Constants – Ivory", "scope": ["constant", "constant.language"], "settings": { "foreground": "#F5E6B0", "fontStyle": "bold" } },
    { "name": "Boolean / Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#FFEA80", "fontStyle": "italic" } },

    { "name": "Functions – Crown Jewel", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#FFEA80" } },
    { "name": "Parameters – Aged Parchment", "scope": ["variable.parameter"], "settings": { "foreground": "#C9A840", "fontStyle": "italic" } },
    { "name": "Arrow Functions", "scope": ["storage.type.function.arrow"], "settings": { "foreground": "#CC0000" } },

    { "name": "Classes – Pure Gold", "scope": ["entity.name.class", "entity.name.type.class", "support.class"], "settings": { "foreground": "#FFD700", "fontStyle": "bold" } },
    { "name": "Types – Bronze", "scope": ["entity.name.type", "support.type", "storage.type.primitive"], "settings": { "foreground": "#DAA520" } },
    { "name": "Interfaces", "scope": ["entity.name.type.interface", "entity.name.type.enum"], "settings": { "foreground": "#BB9900", "fontStyle": "italic" } },

    { "name": "Variables – Wealth Green", "scope": ["variable", "variable.other", "variable.other.readwrite"], "settings": { "foreground": "#88BB00" } },
    { "name": "Properties – Burnished Gold", "scope": ["variable.other.property", "support.variable.property"], "settings": { "foreground": "#C9A840" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#FFEA80" } },
    { "name": "this/self", "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#CC0000", "fontStyle": "italic" } },

    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#CC0000", "fontStyle": "bold" } },

    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#7A6530" } },
    { "name": "Brackets", "scope": ["punctuation.definition.block", "meta.brace"], "settings": { "foreground": "#9A8050" } },

    { "name": "Decorators", "scope": ["meta.decorator", "entity.name.function.decorator"], "settings": { "foreground": "#BB77BB", "fontStyle": "italic" } },

    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#CC0000" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#C9A840", "fontStyle": "italic" } },
    { "name": "JSX Components", "scope": ["support.class.component", "entity.name.tag.tsx"], "settings": { "foreground": "#FFD700", "fontStyle": "bold" } },

    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"], "settings": { "foreground": "#CC0000" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#C9A840" } },
    { "name": "CSS Values", "scope": ["meta.property-value.css"], "settings": { "foreground": "#FFD700" } },

    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#FFEA80" } },

    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#FFD700", "fontStyle": "bold" } },
    { "name": "Markdown Bold", "scope": ["markup.bold"], "settings": { "foreground": "#F5E6B0", "fontStyle": "bold" } },
    { "name": "Markdown Links", "scope": ["markup.underline.link"], "settings": { "foreground": "#88AACC" } },

    { "name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#FFD700", "bold": true },
    "interface": { "foreground": "#BB9900", "italic": true },
    "function": { "foreground": "#FFEA80" },
    "method": { "foreground": "#FFEA80" },
    "property": { "foreground": "#C9A840" },
    "variable": { "foreground": "#88BB00" },
    "variable.readonly": { "foreground": "#F5E6B0", "bold": true },
    "parameter": { "foreground": "#C9A840", "italic": true },
    "type": { "foreground": "#DAA520" },
    "keyword": { "foreground": "#CC0000", "bold": true },
    "string": { "foreground": "#FFD700" },
    "number": { "foreground": "#E6B800" },
    "comment": { "foreground": "#5A4825", "italic": true }
  }
}
