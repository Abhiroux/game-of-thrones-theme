  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#CBD5E1" } },

    { "name": "Comments – Grey Whisper", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#3F5468", "fontStyle": "italic" } },

    { "name": "Keywords – Stark Steel", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#FF7B72", "fontStyle": "bold" } },
    { "name": "Operators", "scope": ["keyword.operator", "keyword.operator.logical"], "settings": { "foreground": "#8096AB" } },

    { "name": "Strings – Winter Parchment", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#A5D6FF" } },
    { "name": "String Escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#56D364" } },
    { "name": "Template Expression", "scope": ["punctuation.definition.template-expression"], "settings": { "foreground": "#E3B341" } },

    { "name": "Numbers – Frost Blue", "scope": ["constant.numeric"], "settings": { "foreground": "#79C0FF" } },
    { "name": "Constants – Ice White", "scope": ["constant", "constant.language"], "settings": { "foreground": "#E8F0FE", "fontStyle": "bold" } },
    { "name": "Boolean / Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#79C0FF", "fontStyle": "italic" } },

    { "name": "Functions – Ice Blue", "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"], "settings": { "foreground": "#79B8FF" } },
    { "name": "Parameters – Winter Gold", "scope": ["variable.parameter"], "settings": { "foreground": "#E3B341", "fontStyle": "italic" } },
    { "name": "Arrow Functions", "scope": ["storage.type.function.arrow"], "settings": { "foreground": "#FF7B72" } },

    { "name": "Classes – Direwolf White", "scope": ["entity.name.class", "entity.name.type.class", "support.class"], "settings": { "foreground": "#E8F0FE", "fontStyle": "bold" } },
    { "name": "Types – Lavender", "scope": ["entity.name.type", "support.type", "storage.type.primitive"], "settings": { "foreground": "#D2A8FF" } },
    { "name": "Interfaces", "scope": ["entity.name.type.interface", "entity.name.type.enum"], "settings": { "foreground": "#BC8CFF", "fontStyle": "italic" } },

    { "name": "Variables – Frost Green", "scope": ["variable", "variable.other", "variable.other.readwrite"], "settings": { "foreground": "#56D364" } },
    { "name": "Properties – Muted Steel", "scope": ["variable.other.property", "support.variable.property"], "settings": { "foreground": "#8096AB" } },
    { "name": "Object Keys", "scope": ["meta.objectliteral string.key", "support.type.property-name"], "settings": { "foreground": "#A5D6FF" } },
    { "name": "this/self", "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#FF7B72", "fontStyle": "italic" } },

    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FF7B72", "fontStyle": "bold" } },

    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator", "punctuation.accessor"], "settings": { "foreground": "#5A6F82" } },
    { "name": "Brackets", "scope": ["punctuation.definition.block", "meta.brace", "punctuation.bracket"], "settings": { "foreground": "#6B8098" } },

    { "name": "Decorators – Rune Purple", "scope": ["meta.decorator", "entity.name.function.decorator"], "settings": { "foreground": "#BC8CFF", "fontStyle": "italic" } },

    { "name": "HTML Tags – Steel Blue", "scope": ["entity.name.tag"], "settings": { "foreground": "#79B8FF" } },
    { "name": "HTML Attributes – Gold", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E3B341", "fontStyle": "italic" } },
    { "name": "JSX Components", "scope": ["support.class.component", "entity.name.tag.tsx"], "settings": { "foreground": "#E8F0FE", "fontStyle": "bold" } },

    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"], "settings": { "foreground": "#79B8FF" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#8096AB" } },
    { "name": "CSS Values", "scope": ["meta.property-value.css", "support.constant.property-value.css"], "settings": { "foreground": "#A5D6FF" } },
    { "name": "CSS IDs", "scope": ["entity.other.attribute-name.id.css"], "settings": { "foreground": "#E3B341" } },

    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#79B8FF" } },

    { "name": "Markdown Headings", "scope": ["markup.heading", "entity.name.section.markdown"], "settings": { "foreground": "#79B8FF", "fontStyle": "bold" } },
    { "name": "Markdown Bold", "scope": ["markup.bold"], "settings": { "foreground": "#E8F0FE", "fontStyle": "bold" } },
    { "name": "Markdown Italic", "scope": ["markup.italic"], "settings": { "foreground": "#CBD5E1", "fontStyle": "italic" } },
    { "name": "Markdown Code", "scope": ["markup.raw.inline", "markup.fenced_code"], "settings": { "foreground": "#A5D6FF" } },
    { "name": "Markdown Links", "scope": ["markup.underline.link"], "settings": { "foreground": "#39C5CF" } },

    { "name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } },
    { "name": "Deprecated", "scope": ["invalid.deprecated"], "settings": { "foreground": "#E3B341", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#E8F0FE", "bold": true },
    "interface": { "foreground": "#BC8CFF", "italic": true },
    "enum": { "foreground": "#D2A8FF" },
    "enumMember": { "foreground": "#A5D6FF" },
    "function": { "foreground": "#79B8FF" },
    "method": { "foreground": "#79B8FF" },
    "property": { "foreground": "#8096AB" },
    "variable": { "foreground": "#56D364" },
    "variable.readonly": { "foreground": "#E8F0FE", "bold": true },
    "parameter": { "foreground": "#E3B341", "italic": true },
    "type": { "foreground": "#D2A8FF" },
    "namespace": { "foreground": "#BC8CFF" },
    "keyword": { "foreground": "#FF7B72", "bold": true },
    "string": { "foreground": "#A5D6FF" },
    "number": { "foreground": "#79C0FF" },
    "decorator": { "foreground": "#BC8CFF", "italic": true },
    "comment": { "foreground": "#3F5468", "italic": true }
  }
}
