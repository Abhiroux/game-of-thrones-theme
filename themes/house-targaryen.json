  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#F0C8B8" } },

    { "name": "Comments – Dragon Smoke", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4A2828", "fontStyle": "italic" } },

    { "name": "Keywords – Dragon Fire", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#FF4500", "fontStyle": "bold" } },
    { "name": "Operators – Ember", "scope": ["keyword.operator"], "settings": { "foreground": "#CC6633" } },

    { "name": "Strings – Molten Orange", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#FF8C00" } },
    { "name": "String Escape – Wildfire", "scope": ["constant.character.escape"], "settings": { "foreground": "#5FD700" } },
    { "name": "Template Expression", "scope": ["punctuation.definition.template-expression"], "settings": { "foreground": "#FFA500" } },

    { "name": "Numbers – Flame Orange", "scope": ["constant.numeric"], "settings": { "foreground": "#FFA500" } },
    { "name": "Constants – Dragon Bone", "scope": ["constant", "constant.language"], "settings": { "foreground": "#F0D0C0", "fontStyle": "bold" } },
    { "name": "Boolean / Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#FF6347", "fontStyle": "italic" } },

    { "name": "Functions – Dragonscale", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#FF6347" } },
    { "name": "Parameters – Ashen", "scope": ["variable.parameter"], "settings": { "foreground": "#C07060", "fontStyle": "italic" } },
    { "name": "Arrow Functions", "scope": ["storage.type.function.arrow"], "settings": { "foreground": "#FF4500" } },

    { "name": "Classes – Flame Bright", "scope": ["entity.name.class", "entity.name.type.class", "support.class"], "settings": { "foreground": "#FF4500", "fontStyle": "bold" } },
    { "name": "Types – Deep Red", "scope": ["entity.name.type", "support.type", "storage.type.primitive"], "settings": { "foreground": "#E03311" } },
    { "name": "Interfaces", "scope": ["entity.name.type.interface", "entity.name.type.enum"], "settings": { "foreground": "#CC0099", "fontStyle": "italic" } },

    { "name": "Variables – Embers", "scope": ["variable", "variable.other", "variable.other.readwrite"], "settings": { "foreground": "#CC5544" } },
    { "name": "Properties – Warm Ash", "scope": ["variable.other.property", "support.variable.property"], "settings": { "foreground": "#B08070" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#FF6347" } },
    { "name": "this/self", "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#FF4500", "fontStyle": "italic" } },

    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FF4500", "fontStyle": "bold" } },

    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#6A4030" } },
    { "name": "Brackets", "scope": ["punctuation.definition.block", "meta.brace"], "settings": { "foreground": "#8A5540" } },

    { "name": "Decorators – Magenta Fire", "scope": ["meta.decorator", "entity.name.function.decorator"], "settings": { "foreground": "#CC0099", "fontStyle": "italic" } },

    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#FF4500" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#CC6633", "fontStyle": "italic" } },
    { "name": "JSX Components", "scope": ["support.class.component", "entity.name.tag.tsx"], "settings": { "foreground": "#FF4500", "fontStyle": "bold" } },

    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"], "settings": { "foreground": "#FF4500" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#B08070" } },
    { "name": "CSS Values", "scope": ["meta.property-value.css"], "settings": { "foreground": "#FF8C00" } },

    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#FF6347" } },

    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#FF4500", "fontStyle": "bold" } },
    { "name": "Markdown Bold", "scope": ["markup.bold"], "settings": { "foreground": "#F0D0C0", "fontStyle": "bold" } },
    { "name": "Markdown Links", "scope": ["markup.underline.link"], "settings": { "foreground": "#4D99B0" } },

    { "name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#FF4500", "bold": true },
    "interface": { "foreground": "#CC0099", "italic": true },
    "function": { "foreground": "#FF6347" },
    "method": { "foreground": "#FF6347" },
    "property": { "foreground": "#B08070" },
    "variable": { "foreground": "#CC5544" },
    "variable.readonly": { "foreground": "#F0D0C0", "bold": true },
    "parameter": { "foreground": "#C07060", "italic": true },
    "type": { "foreground": "#E03311" },
    "keyword": { "foreground": "#FF4500", "bold": true },
    "string": { "foreground": "#FF8C00" },
    "number": { "foreground": "#FFA500" },
    "comment": { "foreground": "#4A2828", "italic": true }
  }
}
