  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#E0F0FF" } },

    { "name": "Comments – Ice Whisper", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#1A4A6A", "fontStyle": "italic" } },

    { "name": "Keywords – Blizzard White", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#E0F0FF", "fontStyle": "bold" } },
    { "name": "Operators – Ice", "scope": ["keyword.operator"], "settings": { "foreground": "#5A9AC0" } },

    { "name": "Strings – Frozen Gold", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#FFD700" } },
    { "name": "String Escape – Aurora", "scope": ["constant.character.escape"], "settings": { "foreground": "#00FF7F" } },
    { "name": "Template Expression", "scope": ["punctuation.definition.template-expression"], "settings": { "foreground": "#FFFF00" } },

    { "name": "Numbers – Deep Water Cyan", "scope": ["constant.numeric"], "settings": { "foreground": "#00CED1" } },
    { "name": "Constants – Pure White", "scope": ["constant", "constant.language"], "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" } },
    { "name": "Boolean / Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#00CED1", "fontStyle": "italic" } },

    { "name": "Functions – Arctic Blue", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#00BFFF" } },
    { "name": "Parameters – Frost Blue", "scope": ["variable.parameter"], "settings": { "foreground": "#5A9AC0", "fontStyle": "italic" } },
    { "name": "Arrow Functions", "scope": ["storage.type.function.arrow"], "settings": { "foreground": "#E0F0FF" } },

    { "name": "Classes – Glacier White", "scope": ["entity.name.class", "entity.name.type.class", "support.class"], "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" } },
    { "name": "Types – Spectral Purple", "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#AA44FF" } },
    { "name": "Interfaces", "scope": ["entity.name.type.interface", "entity.name.type.enum"], "settings": { "foreground": "#CC88FF", "fontStyle": "italic" } },

    { "name": "Variables – Ice Green", "scope": ["variable", "variable.other"], "settings": { "foreground": "#00FF7F" } },
    { "name": "Properties – Frozen Steel", "scope": ["variable.other.property"], "settings": { "foreground": "#7FB8D8" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#00BFFF" } },
    { "name": "this/self", "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#E0F0FF", "fontStyle": "italic" } },

    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export"], "settings": { "foreground": "#E0F0FF", "fontStyle": "bold" } },

    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#2A5A8A" } },
    { "name": "Brackets", "scope": ["punctuation.definition.block", "meta.brace"], "settings": { "foreground": "#3A6A9A" } },

    { "name": "Decorators – Aurora Purple", "scope": ["meta.decorator", "entity.name.function.decorator"], "settings": { "foreground": "#CC88FF", "fontStyle": "italic" } },

    { "name": "HTML Tags – Arctic Blue", "scope": ["entity.name.tag"], "settings": { "foreground": "#00BFFF" } },
    { "name": "HTML Attributes – Frozen Gold", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FFD700", "fontStyle": "italic" } },
    { "name": "JSX Components", "scope": ["support.class.component", "entity.name.tag.tsx"], "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" } },

    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"], "settings": { "foreground": "#00BFFF" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#7FB8D8" } },
    { "name": "CSS Values", "scope": ["meta.property-value.css"], "settings": { "foreground": "#FFD700" } },

    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#00BFFF" } },

    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#00BFFF", "fontStyle": "bold" } },
    { "name": "Markdown Bold", "scope": ["markup.bold"], "settings": { "foreground": "#FFFFFF", "fontStyle": "bold" } },
    { "name": "Markdown Code", "scope": ["markup.raw.inline", "markup.fenced_code"], "settings": { "foreground": "#00CED1" } },
    { "name": "Markdown Links", "scope": ["markup.underline.link"], "settings": { "foreground": "#00CED1" } },

    { "name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#FFFFFF", "bold": true },
    "interface": { "foreground": "#CC88FF", "italic": true },
    "function": { "foreground": "#00BFFF" },
    "method": { "foreground": "#00BFFF" },
    "property": { "foreground": "#7FB8D8" },
    "variable": { "foreground": "#00FF7F" },
    "variable.readonly": { "foreground": "#FFFFFF", "bold": true },
    "parameter": { "foreground": "#5A9AC0", "italic": true },
    "type": { "foreground": "#AA44FF" },
    "keyword": { "foreground": "#E0F0FF", "bold": true },
    "string": { "foreground": "#FFD700" },
    "number": { "foreground": "#00CED1" },
    "comment": { "foreground": "#1A4A6A", "italic": true }
  }
}
