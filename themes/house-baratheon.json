  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#D0C8B8" } },
    { "name": "Comments – Storm Cloud", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#404048", "fontStyle": "italic" } },
    { "name": "Keywords – Thunder", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#B0B0B0", "fontStyle": "bold" } },
    { "name": "Operators", "scope": ["keyword.operator"], "settings": { "foreground": "#808080" } },
    { "name": "Strings – Royal Gold", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#DAA520" } },
    { "name": "Escape – Lightning", "scope": ["constant.character.escape"], "settings": { "foreground": "#FFD700" } },
    { "name": "Template", "scope": ["punctuation.definition.template-expression"], "settings": { "foreground": "#E0C060" } },
    { "name": "Numbers – War Hammer", "scope": ["constant.numeric"], "settings": { "foreground": "#E0A000" } },
    { "name": "Constants", "scope": ["constant", "constant.language"], "settings": { "foreground": "#E8E0D0", "fontStyle": "bold" } },
    { "name": "Boolean/Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#B0A080", "fontStyle": "italic" } },
    { "name": "Functions – War Cry", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#C0B070" } },
    { "name": "Parameters", "scope": ["variable.parameter"], "settings": { "foreground": "#8A8070", "fontStyle": "italic" } },
    { "name": "Arrow", "scope": ["storage.type.function.arrow"], "settings": { "foreground": "#B0B0B0" } },
    { "name": "Classes – Crowned Stag", "scope": ["entity.name.class", "support.class"], "settings": { "foreground": "#DAA520", "fontStyle": "bold" } },
    { "name": "Types", "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#B0A060" } },
    { "name": "Variables – Iron", "scope": ["variable", "variable.other"], "settings": { "foreground": "#7A8A7A" } },
    { "name": "Properties", "scope": ["variable.other.property"], "settings": { "foreground": "#8A8070" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#C0B070" } },
    { "name": "this/self", "scope": ["variable.language.this"], "settings": { "foreground": "#B0B0B0", "fontStyle": "italic" } },
    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export"], "settings": { "foreground": "#B0B0B0", "fontStyle": "bold" } },
    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#5A5A5A" } },
    { "name": "Brackets", "scope": ["meta.brace", "punctuation.definition.block"], "settings": { "foreground": "#6A6A6A" } },
    { "name": "Decorators", "scope": ["meta.decorator"], "settings": { "foreground": "#9A7A9A", "fontStyle": "italic" } },
    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#B0B0B0" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#DAA520", "fontStyle": "italic" } },
    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#C0B070" } },
    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#DAA520", "fontStyle": "bold" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#DAA520", "bold": true },
    "function": { "foreground": "#C0B070" },
    "variable": { "foreground": "#7A8A7A" },
    "property": { "foreground": "#8A8070" },
    "parameter": { "foreground": "#8A8070", "italic": true },
    "keyword": { "foreground": "#B0B0B0", "bold": true },
    "string": { "foreground": "#DAA520" },
    "number": { "foreground": "#E0A000" },
    "type": { "foreground": "#B0A060" },
    "comment": { "foreground": "#404048", "italic": true }
  }
}
