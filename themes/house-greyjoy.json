  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#B0C4D8" } },
    { "name": "Comments – Deep Water", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2A4A5A", "fontStyle": "italic" } },
    { "name": "Keywords – Iron Price", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#90C0D0", "fontStyle": "bold" } },
    { "name": "Operators", "scope": ["keyword.operator"], "settings": { "foreground": "#5A7A8A" } },
    { "name": "Strings – Salt Spray", "scope": ["string", "string.quoted"], "settings": { "foreground": "#5AAABA" } },
    { "name": "Escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#3A9A6A" } },
    { "name": "Numbers – Treasure", "scope": ["constant.numeric"], "settings": { "foreground": "#BABA40" } },
    { "name": "Constants – Driftwood", "scope": ["constant", "constant.language"], "settings": { "foreground": "#D0D8E0", "fontStyle": "bold" } },
    { "name": "Boolean", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#7AAFCF", "fontStyle": "italic" } },
    { "name": "Functions – Kraken Arm", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#7AAFCF" } },
    { "name": "Parameters", "scope": ["variable.parameter"], "settings": { "foreground": "#6A8A9A", "fontStyle": "italic" } },
    { "name": "Classes – Ship Name", "scope": ["entity.name.class", "support.class"], "settings": { "foreground": "#90C0D0", "fontStyle": "bold" } },
    { "name": "Types – Rope", "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#5A9AB0" } },
    { "name": "Variables – Sea Foam", "scope": ["variable", "variable.other"], "settings": { "foreground": "#6A9A7A" } },
    { "name": "Properties – Barnacle", "scope": ["variable.other.property"], "settings": { "foreground": "#6A8A9A" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#7AAFCF" } },
    { "name": "this", "scope": ["variable.language.this"], "settings": { "foreground": "#90C0D0", "fontStyle": "italic" } },
    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export"], "settings": { "foreground": "#90C0D0", "fontStyle": "bold" } },
    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#3A5A6A" } },
    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#7AAFCF" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#5AAABA", "fontStyle": "italic" } },
    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#7AAFCF" } },
    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#7AAFCF", "fontStyle": "bold" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#90C0D0", "bold": true },
    "function": { "foreground": "#7AAFCF" },
    "variable": { "foreground": "#6A9A7A" },
    "property": { "foreground": "#6A8A9A" },
    "keyword": { "foreground": "#90C0D0", "bold": true },
    "string": { "foreground": "#5AAABA" },
    "number": { "foreground": "#BABA40" },
    "comment": { "foreground": "#2A4A5A", "italic": true }
  }
}
