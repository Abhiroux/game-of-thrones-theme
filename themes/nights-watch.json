  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#A8A8A8" } },

    { "name": "Comments – Black Ice", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#333333", "fontStyle": "italic" } },

    { "name": "Keywords – Cold Steel", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#909090", "fontStyle": "bold" } },
    { "name": "Operators", "scope": ["keyword.operator"], "settings": { "foreground": "#606060" } },

    { "name": "Strings – Dim Torch", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#9A9A6A" } },
    { "name": "String Escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#6A9A6A" } },

    { "name": "Numbers – Moonlight", "scope": ["constant.numeric"], "settings": { "foreground": "#7A7A5A" } },
    { "name": "Constants – Frost", "scope": ["constant", "constant.language"], "settings": { "foreground": "#C0C0C0", "fontStyle": "bold" } },
    { "name": "Boolean / Null", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#7A8A7A", "fontStyle": "italic" } },

    { "name": "Functions – Wall Ice", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#A0A0A0" } },
    { "name": "Parameters – Mist", "scope": ["variable.parameter"], "settings": { "foreground": "#707070", "fontStyle": "italic" } },

    { "name": "Classes – Snow White", "scope": ["entity.name.class", "entity.name.type.class", "support.class"], "settings": { "foreground": "#C0C0C0", "fontStyle": "bold" } },
    { "name": "Types – Ghost", "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#909090" } },

    { "name": "Variables – Forest Shadow", "scope": ["variable", "variable.other"], "settings": { "foreground": "#7A8A7A" } },
    { "name": "Properties – Stone", "scope": ["variable.other.property"], "settings": { "foreground": "#686868" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#8A8A8A" } },
    { "name": "this/self", "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#808080", "fontStyle": "italic" } },

    { "name": "Import/Export", "scope": ["keyword.control.import", "keyword.control.export"], "settings": { "foreground": "#808080", "fontStyle": "bold" } },

    { "name": "Punctuation", "scope": ["punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#404040" } },
    { "name": "Brackets", "scope": ["punctuation.definition.block", "meta.brace"], "settings": { "foreground": "#505050" } },

    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#808080" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#686868", "fontStyle": "italic" } },

    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"], "settings": { "foreground": "#808080" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#707070" } },

    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#8A8A8A" } },

    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#B0B0B0", "fontStyle": "bold" } },

    { "name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#CC2222", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#C0C0C0", "bold": true },
    "function": { "foreground": "#A0A0A0" },
    "method": { "foreground": "#A0A0A0" },
    "property": { "foreground": "#686868" },
    "variable": { "foreground": "#7A8A7A" },
    "variable.readonly": { "foreground": "#C0C0C0", "bold": true },
    "parameter": { "foreground": "#707070", "italic": true },
    "type": { "foreground": "#909090" },
    "keyword": { "foreground": "#909090", "bold": true },
    "string": { "foreground": "#9A9A6A" },
    "number": { "foreground": "#7A7A5A" },
    "comment": { "foreground": "#333333", "italic": true }
  }
}
