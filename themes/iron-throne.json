  "tokenColors": [

    {
      "name": "Reset / Base",
      "scope": ["source", "text"],
      "settings": { "foreground": "#D4C5A9" }
    },

    "_comment COMMENTS",
    {
      "name": "Comments – Maester's Ink (muted italic)",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#5C6A70", "fontStyle": "italic" }
    },

    "_comment KEYWORDS",
    {
      "name": "Keywords – Targaryen Fire (bold red)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.unit",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#C0392B", "fontStyle": "bold" }
    },
    {
      "name": "Keyword Operators",
      "scope": ["keyword.operator", "keyword.operator.logical", "keyword.operator.arithmetic"],
      "settings": { "foreground": "#E07B54" }
    },

    "_comment STRINGS",
    {
      "name": "Strings – Lannister Gold",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "string.regexp"
      ],
      "settings": { "foreground": "#CFB53B" }
    },
    {
      "name": "String Escape – Wildfire",
      "scope": ["constant.character.escape", "string.escape"],
      "settings": { "foreground": "#5FD700" }
    },
    {
      "name": "Template Literals Interpolation",
      "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"],
      "settings": { "foreground": "#E67E22" }
    },

    "_comment NUMBERS",
    {
      "name": "Numbers – Wildfire Orange",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#E67E22" }
    },

    "_comment CONSTANTS",
    {
      "name": "Constants – Night's Watch White",
      "scope": ["constant", "constant.language", "constant.other"],
      "settings": { "foreground": "#ECF0F1", "fontStyle": "bold" }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#A8D8EA", "fontStyle": "italic" }
    },

    "_comment FUNCTIONS",
    {
      "name": "Function Names – White Walker Ice",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.function.call"
      ],
      "settings": { "foreground": "#A8D8EA" }
    },
    {
      "name": "Function Parameters – Parchment Italic",
      "scope": ["variable.parameter", "meta.parameters variable.other"],
      "settings": { "foreground": "#C9A86C", "fontStyle": "italic" }
    },
    {
      "name": "Arrow / Lambda",
      "scope": ["storage.type.function.arrow", "keyword.operator.arrow"],
      "settings": { "foreground": "#E07B54" }
    },

    "_comment CLASSES",
    {
      "name": "Class Names – Lannister Royal",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#F1C40F", "fontStyle": "bold" }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "entity.name.type",
        "support.type",
        "keyword.operator.type",
        "meta.type.annotation entity.name.type",
        "storage.type.primitive"
      ],
      "settings": { "foreground": "#E8C547" }
    },
    {
      "name": "Interfaces / Enums",
      "scope": ["entity.name.type.interface", "entity.name.type.enum"],
      "settings": { "foreground": "#F0D060", "fontStyle": "italic" }
    },

    "_comment VARIABLES",
    {
      "name": "Variables – Meadow Green",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#7EC8A0" }
    },
    {
      "name": "Properties – Aged Copper",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": { "foreground": "#9DB5A8" }
    },
    {
      "name": "Object Keys",
      "scope": ["meta.objectliteral string.key", "support.type.property-name"],
      "settings": { "foreground": "#BDB49A" }
    },
    {
      "name": "this / self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#E07B54", "fontStyle": "italic" }
    },
    {
      "name": "Global Variables",
      "scope": ["variable.language"],
      "settings": { "foreground": "#E07B54" }
    },

    "_comment IMPORTS",
    {
      "name": "Import / Module",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "meta.import keyword.control"
      ],
      "settings": { "foreground": "#C0392B", "fontStyle": "bold" }
    },
    {
      "name": "Import Path Strings",
      "scope": ["meta.import string", "source.js string.quoted.single meta.import"],
      "settings": { "foreground": "#CFB53B" }
    },

    "_comment OPERATORS",
    {
      "name": "Punctuation / Operators",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": { "foreground": "#7A6F5A" }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.section.block",
        "meta.brace",
        "punctuation.bracket"
      ],
      "settings": { "foreground": "#8A7A60" }
    },

    "_comment DECORATORS",
    {
      "name": "Decorators / Annotations – Maester's Seal",
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#9B59B6", "fontStyle": "italic" }
    },

    "_comment HTML / JSX / MARKUP",
    {
      "name": "HTML Tags – Castle Stone",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": { "foreground": "#85A0B8" }
    },
    {
      "name": "HTML Attributes – Parchment",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.inline entity.other.attribute-name"
      ],
      "settings": { "foreground": "#BDA97A", "fontStyle": "italic" }
    },
    {
      "name": "HTML Attribute Values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#CFB53B" }
    },
    {
      "name": "JSX Component Names",
      "scope": ["support.class.component", "entity.name.tag.tsx", "entity.name.tag.jsx"],
      "settings": { "foreground": "#F1C40F", "fontStyle": "bold" }
    },
    {
      "name": "JSX Expression Brackets",
      "scope": ["punctuation.section.embedded.begin.jsx", "punctuation.section.embedded.end.jsx"],
      "settings": { "foreground": "#E67E22" }
    },

    "_comment CSS",
    {
      "name": "CSS Selectors – Raven Black",
      "scope": [
        "entity.name.tag.css",
        "meta.selector",
        "entity.other.attribute-name.class.css"
      ],
      "settings": { "foreground": "#85A0B8" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#9DB5A8" }
    },
    {
      "name": "CSS Values",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": { "foreground": "#CFB53B" }
    },
    {
      "name": "CSS Units",
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#E67E22" }
    },
    {
      "name": "CSS Colors",
      "scope": ["constant.other.color.rgb-value.css"],
      "settings": { "foreground": "#CFB53B" }
    },
    {
      "name": "CSS IDs",
      "scope": ["entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#F1C40F" }
    },
    {
      "name": "CSS At-Rules",
      "scope": ["keyword.control.at-rule", "punctuation.definition.keyword.css"],
      "settings": { "foreground": "#C0392B" }
    },

    "_comment PYTHON",
    {
      "name": "Python Builtins",
      "scope": ["support.function.builtin.python"],
      "settings": { "foreground": "#A8D8EA" }
    },
    {
      "name": "Python Decorators",
      "scope": ["entity.name.function.decorator.python"],
      "settings": { "foreground": "#9B59B6" }
    },
    {
      "name": "Python Self",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": { "foreground": "#E07B54", "fontStyle": "italic" }
    },

    "_comment RUST",
    {
      "name": "Rust Lifetimes",
      "scope": ["entity.name.lifetime.rust", "storage.modifier.lifetime.rust"],
      "settings": { "foreground": "#9B59B6" }
    },
    {
      "name": "Rust Macros",
      "scope": ["entity.name.function.macro.rust", "support.function.macro.rust"],
      "settings": { "foreground": "#E67E22" }
    },

    "_comment MARKDOWN",
    {
      "name": "Markdown Headings – Gold",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#CFB53B", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#F5F5F5", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#D4C5A9", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.raw.inline", "markup.fenced_code"],
      "settings": { "foreground": "#A8D8EA", "fontStyle": "" }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#5DADE2" }
    },
    {
      "name": "Markdown Blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6C7A89", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List Bullets",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#8B0000" }
    },

    "_comment JSON",
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#A8D8EA" }
    },
    {
      "name": "JSON String Values",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#CFB53B" }
    },
    {
      "name": "JSON Booleans / Null",
      "scope": ["constant.language.json"],
      "settings": { "foreground": "#A8D8EA", "fontStyle": "italic" }
    },

    "_comment YAML",
    {
      "name": "YAML Keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#A8D8EA" }
    },
    {
      "name": "YAML Anchors",
      "scope": ["entity.name.type.anchor.yaml"],
      "settings": { "foreground": "#9B59B6" }
    },

    "_comment SHELL",
    {
      "name": "Shell Commands",
      "scope": ["support.function.builtin.shell"],
      "settings": { "foreground": "#A8D8EA" }
    },
    {
      "name": "Shell Flags",
      "scope": ["string.unquoted.argument.shell"],
      "settings": { "foreground": "#7EC8A0" }
    },

    "_comment INVALID",
    {
      "name": "Invalid – Broken Oath Red",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#E67E22", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#F1C40F", "bold": true },
    "interface": { "foreground": "#F0D060", "italic": true },
    "enum": { "foreground": "#E8C547" },
    "enumMember": { "foreground": "#CFB53B" },
    "function": { "foreground": "#A8D8EA" },
    "method": { "foreground": "#A8D8EA" },
    "property": { "foreground": "#9DB5A8" },
    "variable": { "foreground": "#7EC8A0" },
    "variable.readonly": { "foreground": "#ECF0F1", "bold": true },
    "parameter": { "foreground": "#C9A86C", "italic": true },
    "type": { "foreground": "#E8C547" },
    "namespace": { "foreground": "#9B59B6" },
    "keyword": { "foreground": "#C0392B", "bold": true },
    "string": { "foreground": "#CFB53B" },
    "number": { "foreground": "#E67E22" },
    "decorator": { "foreground": "#9B59B6", "italic": true },
    "comment": { "foreground": "#5C6A70", "italic": true },
    "macro": { "foreground": "#E67E22" },
    "lifetime": { "foreground": "#9B59B6" },
    "selfKeyword": { "foreground": "#E07B54", "italic": true },
    "builtinType": { "foreground": "#A8D8EA" }
  }
}
