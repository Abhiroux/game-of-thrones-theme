  "tokenColors": [
    { "scope": ["source", "text"], "settings": { "foreground": "#E0D0B0" } },
    { "name": "Comments – Sand Whisper", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5A4830", "fontStyle": "italic" } },
    { "name": "Keywords – Sun Spear", "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#CC3333", "fontStyle": "bold" } },
    { "name": "Operators – Dune", "scope": ["keyword.operator"], "settings": { "foreground": "#B09060" } },
    { "name": "Strings – Desert Gold", "scope": ["string", "string.quoted"], "settings": { "foreground": "#F4A460" } },
    { "name": "Escape – Viper Bite", "scope": ["constant.character.escape"], "settings": { "foreground": "#7AAA3A" } },
    { "name": "Numbers – Sunstone", "scope": ["constant.numeric"], "settings": { "foreground": "#DEB887" } },
    { "name": "Constants – Ivory", "scope": ["constant", "constant.language"], "settings": { "foreground": "#F0E0C0", "fontStyle": "bold" } },
    { "name": "Boolean", "scope": ["constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#CD853F", "fontStyle": "italic" } },
    { "name": "Functions – Viper Strike", "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#FF8C00" } },
    { "name": "Parameters – Silk", "scope": ["variable.parameter"], "settings": { "foreground": "#B09060", "fontStyle": "italic" } },
    { "name": "Classes – Sun Prince", "scope": ["entity.name.class", "support.class"], "settings": { "foreground": "#FF8C00", "fontStyle": "bold" } },
    { "name": "Types – Terracotta", "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#D2691E" } },
    { "name": "Variables – Oasis Green", "scope": ["variable", "variable.other"], "settings": { "foreground": "#8AAA6A" } },
    { "name": "Properties – Sand", "scope": ["variable.other.property"], "settings": { "foreground": "#B09060" } },
    { "name": "Object Keys", "scope": ["support.type.property-name"], "settings": { "foreground": "#F4A460" } },
    { "name": "this", "scope": ["variable.language.this"], "settings": { "foreground": "#CC3333", "fontStyle": "italic" } },
    { "name": "Imports", "scope": ["keyword.control.import", "keyword.control.export"], "settings": { "foreground": "#CC3333", "fontStyle": "bold" } },
    { "name": "Punctuation", "scope": ["punctuation.separator"], "settings": { "foreground": "#6A5030" } },
    { "name": "HTML Tags", "scope": ["entity.name.tag"], "settings": { "foreground": "#CC3333" } },
    { "name": "HTML Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#F4A460", "fontStyle": "italic" } },
    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#FF8C00" } },
    { "name": "Markdown Headings", "scope": ["markup.heading"], "settings": { "foreground": "#FF8C00", "fontStyle": "bold" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#FF0000", "fontStyle": "bold underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#FF8C00", "bold": true },
    "function": { "foreground": "#FF8C00" },
    "variable": { "foreground": "#8AAA6A" },
    "property": { "foreground": "#B09060" },
    "keyword": { "foreground": "#CC3333", "bold": true },
    "string": { "foreground": "#F4A460" },
    "number": { "foreground": "#DEB887" },
    "comment": { "foreground": "#5A4830", "italic": true }
  }
}
