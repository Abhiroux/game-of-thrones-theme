{
  "Dragon Class": {
    "prefix": "dragon",
    "body": [
      "class ${1:Dragon} {",
      "  ${2:name}: string;",
      "  fireBreath: boolean;",
      "",
      "  constructor(${2:name}: string) {",
      "    this.${2:name} = ${2:name};",
      "    this.fireBreath = true;",
      "  }",
      "",
      "  ${3:dracarys}(): ${4:void} {",
      "    ${5:// 🔥 Dracarys!}",
      "  }",
      "}"
    ],
    "description": "GOT dragon-themed TypeScript class"
  },
